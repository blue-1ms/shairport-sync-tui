@dataclass
class Snapshot:
    ok: bool
    error: str = ""
    active: bool = False
    available: bool = False
    player_state: str = "Unknown"
    client: str = ""
    client_name: str = ""
    airplay_volume: float | None = None
    volume_percent: float | None = None
    title: str = ""
    artist: str = ""
    album: str = ""
    genre: str = ""
    art_url: str = ""
    elapsed_seconds: float | None = None
    duration_seconds: float | None = None
    progress_estimated: bool = False
    version: str = ""
    updated_at: dt.datetime = field(default_factory=dt.datetime.now)


@dataclass
class UnitStatus:
    name: str
    active: str = "unknown"
    sub: str = "unknown"
    pid: str = "-"
    restarts: str = "-"
    started: str = "-"
    error: str = ""


@dataclass
class AudioStatus:
    backend: str = "-"
    output_device: str = "-"
    mixer: str = "-"
    pulse_server: str = "-"
    default_sink: str = "-"
    alsa_volume: str = "-"
    devices: list[str] = field(default_factory=list)
    errors: list[str] = field(default_factory=list)


@dataclass
class SystemSnapshot:
    units: list[UnitStatus] = field(default_factory=list)
    audio: AudioStatus = field(default_factory=AudioStatus)
    logs: list[str] = field(default_factory=list)
    updated_at: dt.datetime = field(default_factory=dt.datetime.now)


def unwrap(value: Any) -> Any:
    if dbus is not None:
        if isinstance(value, (dbus.String, dbus.ObjectPath)):
            return str(value)
        if isinstance(value, dbus.Boolean):
            return bool(value)
        if isinstance(
            value,
            (
                dbus.Byte,
                dbus.Int16,
                dbus.Int32,
                dbus.Int64,
                dbus.UInt16,
                dbus.UInt32,
                dbus.UInt64,
            ),
        ):
            return int(value)
        if isinstance(value, dbus.Double):
            return float(value)
        if isinstance(value, (dbus.Array, list, tuple)):
            return [unwrap(item) for item in value]
        if isinstance(value, (dbus.Dictionary, dict)):
            return {str(unwrap(key)): unwrap(item) for key, item in value.items()}
    return value


def as_text(value: Any) -> str:
    value = unwrap(value)
    if value is None:
        return ""
    if isinstance(value, (list, tuple)):
        return ", ".join(as_text(item) for item in value if as_text(item))
    return str(value)


def as_bool(value: Any) -> bool:
    return bool(unwrap(value))


def as_float(value: Any) -> float | None:
    try:
        return float(unwrap(value))
    except (TypeError, ValueError):
        return None


def parse_progress(progress: str) -> tuple[float | None, float | None]:
    try:
        start_raw, current_raw, end_raw = (int(part) for part in progress.split("/", 2))
    except (AttributeError, ValueError):
        return None, None

    elapsed = max(0, current_raw - start_raw) / SAMPLE_RATE
    duration = max(0, end_raw - start_raw) / SAMPLE_RATE
    if duration <= 0:
        duration = None
    return elapsed, duration


def format_seconds(seconds: float | None) -> str:
    if seconds is None:
        return "--:--"
    seconds = max(0, int(seconds))
    minutes, seconds = divmod(seconds, 60)
    hours, minutes = divmod(minutes, 60)
    if hours:
        return f"{hours:d}:{minutes:02d}:{seconds:02d}"
    return f"{minutes:d}:{seconds:02d}"


def clamp_int(value: Any, default: int, minimum: int, maximum: int) -> int:
    try:
        number = int(value)
    except (TypeError, ValueError):
        return default
    return max(minimum, min(maximum, number))


def clamp_float(value: Any, default: float, minimum: float, maximum: float) -> float:
    try:
        number = float(value)
    except (TypeError, ValueError):
        return default
    return max(minimum, min(maximum, number))


def load_app_config() -> dict[str, Any]:
    return load_app_config_from(APP_CONFIG_PATH)


def load_app_config_from(path: Path) -> dict[str, Any]:
    config = dict(DEFAULT_APP_CONFIG)
    try:
        loaded = json.loads(path.read_text())
    except FileNotFoundError:
        loaded = {}
    except Exception:
        loaded = {}
    if isinstance(loaded, dict):
        config.update(loaded)
    config["refresh_interval"] = clamp_float(config.get("refresh_interval"), DEFAULT_REFRESH_SECONDS, 0.1, 60.0)
    config["color"] = bool(config.get("color"))
    if config.get("default_view") not in ("main", "debug"):
        config["default_view"] = "main"
    config["history_limit"] = clamp_int(config.get("history_limit"), HISTORY_LIMIT, 1, 200)
    config["log_lines"] = clamp_int(config.get("log_lines"), LOG_LINES, 1, 500)
    return config


def write_default_config(path: Path = APP_CONFIG_PATH) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(DEFAULT_APP_CONFIG, indent=2, sort_keys=True) + "\n")


def status_badge(text: str) -> str:
    value = (text or "unknown").upper()
    return f"[{value}]"


def resolve_hostname(address: str) -> str:
    if not address:
        return ""
    try:
        host, _, _aliases = socket.gethostbyaddr(address)
    except Exception:
        return ""
    return host.rstrip(".")


def run_cmd(args: list[str], timeout: float = 2.0) -> tuple[bool, str]:
    if not shutil.which(args[0]):
        return False, f"{args[0]} not found"
    try:
        completed = subprocess.run(
            args,
            check=False,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            timeout=timeout,
        )
    except Exception as exc:
        return False, str(exc)
    output = completed.stdout.strip() or completed.stderr.strip()
    return completed.returncode == 0, output


class ShairportReader:
    def __init__(self) -> None:
        if dbus is None:
            raise RuntimeError("python3-dbus is not installed")
        self.bus = dbus.SystemBus()
        self.obj = self.bus.get_object(SERVICE, OBJECT)
        self.props = dbus.Interface(self.obj, PROPS)
        self.remote = dbus.Interface(self.obj, REMOTE_IFACE)

    def read(self) -> Snapshot:
        core = self.props.GetAll(CORE_IFACE)
        remote = self.props.GetAll(REMOTE_IFACE)

        metadata = unwrap(remote.get("Metadata", {}))
        elapsed, duration = parse_progress(as_text(remote.get("ProgressString")))
        mpris_length = as_float(metadata.get("mpris:length"))
        if duration is None and mpris_length:
            duration = mpris_length / 1_000_000

        airplay_volume = as_float(remote.get("AirplayVolume"))
        volume_percent = None
        if airplay_volume is not None:
            # AirPlay reports 0 dB as full scale and -30 dB as silence-ish.
            volume_percent = max(0.0, min(100.0, (30.0 + airplay_volume) / 30.0 * 100.0))

        client = as_text(remote.get("Client"))
        return Snapshot(
            ok=True,
            active=as_bool(core.get("Active")),
            available=as_bool(remote.get("Available")),
            player_state=as_text(remote.get("PlayerState")) or "Unknown",
            client=client,
            client_name=resolve_hostname(client),
            airplay_volume=airplay_volume,
            volume_percent=volume_percent,
            title=as_text(metadata.get("xesam:title")),
            artist=as_text(metadata.get("xesam:artist")),
            album=as_text(metadata.get("xesam:album")),
            genre=as_text(metadata.get("xesam:genre")),
            art_url=as_text(metadata.get("mpris:artUrl")),
            elapsed_seconds=elapsed,
            duration_seconds=duration,
            version=as_text(core.get("VersionString")),
        )

    def command(self, name: str) -> str:
        methods = {
            "toggle": "PlayPause",
            "next": "Next",
            "previous": "Previous",
            "stop": "Stop",
            "play": "Play",
            "pause": "Pause",
            "mute": "ToggleMute",
            "volume_up": "VolumeUp",
            "volume_down": "VolumeDown",
        }
        method = methods[name]
        getattr(self.remote, method)()
        return method


class ProgressClock:
    def __init__(self) -> None:
        self.track_key: tuple[str, str, str, float | None] | None = None
        self.anchor_elapsed: float | None = None
        self.anchor_time = time.monotonic()
        self.last_reported_elapsed: float | None = None

    def apply(self, snap: Snapshot) -> Snapshot:
        key = (snap.title, snap.artist, snap.album, snap.duration_seconds)
        now = time.monotonic()
        reported = snap.elapsed_seconds

        if key != self.track_key:
            self.track_key = key
            self.anchor_elapsed = reported
            self.last_reported_elapsed = reported
            self.anchor_time = now
            snap.progress_estimated = False
            return snap

        if reported is not None and (
            self.last_reported_elapsed is None
            or abs(reported - self.last_reported_elapsed) > 0.5
        ):
            self.anchor_elapsed = reported
            self.last_reported_elapsed = reported
            self.anchor_time = now
            snap.progress_estimated = False
            return snap

        if snap.player_state.lower() == "playing" and self.anchor_elapsed is not None:
            elapsed = self.anchor_elapsed + (now - self.anchor_time)
            if snap.duration_seconds is not None:
                elapsed = min(elapsed, snap.duration_seconds)
            snap.elapsed_seconds = elapsed
            snap.progress_estimated = True
        elif self.anchor_elapsed is not None:
            snap.elapsed_seconds = self.anchor_elapsed
            snap.progress_estimated = reported != self.anchor_elapsed

        return snap


class HistoryStore:
    def __init__(self, path: Path = HISTORY_PATH) -> None:
        self.path = path
        self.items: list[dict[str, str]] = []
        self.load()

    def load(self) -> None:
        try:
            data = json.loads(self.path.read_text())
        except Exception:
            data = []
        if isinstance(data, list):
            self.items = [item for item in data if isinstance(item, dict)]

    def save(self) -> None:
        try:
            self.path.parent.mkdir(parents=True, exist_ok=True)
            self.path.write_text(json.dumps(self.items[:HISTORY_LIMIT], indent=2, sort_keys=True) + "\n")
        except Exception:
            pass

    def clear(self) -> None:
        self.items = []
        try:
            self.path.unlink()
        except FileNotFoundError:
            pass
        except Exception:
            self.save()

    def record(self, snap: Snapshot) -> None:
        if not snap.ok or not snap.client:
            return
        now = dt.datetime.now().replace(microsecond=0).isoformat(sep=" ")
        track = " - ".join(part for part in (snap.artist, snap.title) if part)
        existing = next((item for item in self.items if item.get("client") == snap.client), None)
        if existing is None:
            existing = {"client": snap.client, "first_seen": now}
            self.items.insert(0, existing)
        else:
            self.items.remove(existing)
            self.items.insert(0, existing)
        existing["last_seen"] = now
        existing["last_state"] = snap.player_state
        if snap.client_name:
            existing["client_name"] = snap.client_name
        if track:
            existing["last_track"] = track
        del self.items[HISTORY_LIMIT:]
        self.save()


def parse_config() -> dict[str, str]:
    try:
        text = CONFIG_PATH.read_text()
    except Exception:
        return {}
    result: dict[str, str] = {}
    for key in ("output_backend", "output_device", "mixer_control_name", "mixer_device"):
        match = re.search(rf"^\s*{key}\s*=\s*\"([^\"]*)\"", text, re.MULTILINE)
        if match:
            result[key] = match.group(1)
    return result


def read_unit(name: str) -> UnitStatus:
    ok, output = run_cmd(
        [
            "systemctl",
            "show",
            name,
            "--property=Id,ActiveState,SubState,MainPID,NRestarts,ExecMainStartTimestamp",
            "--no-pager",
        ]
    )
    status = UnitStatus(name=name)
    if not ok:
        status.error = output
        return status
    values: dict[str, str] = {}
    for line in output.splitlines():
        if "=" in line:
            key, value = line.split("=", 1)
            values[key] = value
    status.active = values.get("ActiveState") or "unknown"
    status.sub = values.get("SubState") or "unknown"
    status.pid = values.get("MainPID") or "-"
    status.restarts = values.get("NRestarts") or "-"
    status.started = values.get("ExecMainStartTimestamp") or "-"
    return status


def read_audio() -> AudioStatus:
    config = parse_config()
    audio = AudioStatus(
        backend=config.get("output_backend", "alsa"),
        output_device=config.get("output_device", "-"),
        mixer=config.get("mixer_control_name") or config.get("mixer_device") or "-",
    )

    ok, output = run_cmd(["pactl", "info"])
    if ok:
        for line in output.splitlines():
            if line.startswith("Server Name:"):
                audio.pulse_server = line.split(":", 1)[1].strip()
            elif line.startswith("Default Sink:"):
                audio.default_sink = line.split(":", 1)[1].strip()
    else:
        audio.errors.append(output)

    mixer_name = audio.mixer if audio.mixer != "-" else "PCM"
    amixer_args = ["amixer", "get", mixer_name]
    if audio.output_device != "-":
        amixer_args = ["amixer", "-D", audio.output_device, "get", mixer_name]
    ok, output = run_cmd(amixer_args)
    if not ok and audio.output_device != "-":
        ok, output = run_cmd(["amixer", "get", mixer_name])
    if ok:
        matches = re.findall(r"\[(\d+%)\]", output)
        states = re.findall(r"\[(on|off)\]", output)
        if matches:
            audio.alsa_volume = matches[-1] + (f" {states[-1]}" if states else "")
    else:
        audio.errors.append(output)

    ok, output = run_cmd(["aplay", "-l"])
    if ok:
        for line in output.splitlines():
            if line.startswith("card "):
                audio.devices.append(re.sub(r"\s+", " ", line).strip())
                if len(audio.devices) >= 3:
                    break
    else:
        audio.errors.append(output)

    return audio


def read_logs() -> list[str]:
    ok, output = run_cmd(
        ["journalctl", "-u", "shairport-sync.service", "-n", str(LOG_LINES), "--no-pager", "--output=short-iso"],
        timeout=4.0,
    )
    if not ok:
        return [output]
    return [line for line in output.splitlines() if line.strip()][-LOG_LINES:]


class SystemReader:
    def __init__(self) -> None:
        self.next_refresh = 0.0
        self.snapshot = SystemSnapshot()

    def read(self, force: bool = False) -> SystemSnapshot:
        now = time.monotonic()
        if not force and now < self.next_refresh:
            return self.snapshot
        self.snapshot = SystemSnapshot(
            units=[read_unit("shairport-sync.service"), read_unit("avahi-daemon.service")],
            audio=read_audio(),
            logs=read_logs(),
        )
        self.next_refresh = now + SYSTEM_REFRESH_SECONDS
        return self.snapshot


def clipped(text: Any, width: int) -> str:
    text = str(text)
    if width <= 0:
        return ""
    if len(text) <= width:
        return text
    if width <= 1:
        return text[:width]
    return text[: width - 1] + "?"


def pair(number: int) -> int:
    return curses.color_pair(number) if USE_COLOR else 0


def add_line(win: curses.window, row: int, col: int, text: Any, attr: int = 0, max_width: int | None = None) -> None:
    height, width = win.getmaxyx()
    if 0 <= row < height and col < width:
        available = width - col - 1
        if max_width is not None:
            available = min(available, max_width)
        win.addstr(row, col, clipped(text, available), attr)


def draw_bar(win: curses.window, row: int, col: int, width: int, fraction: float | None) -> None:
    width = max(8, width)
    if fraction is None:
        fill = 0
    else:
        fill = max(0, min(width, int(width * fraction)))
    add_line(win, row, col, "[" + "#" * fill + "-" * (width - fill) + "]")


def draw_header(stdscr: curses.window, message: str) -> None:
    _, width = stdscr.getmaxyx()
    title_attr = pair(1) | curses.A_BOLD
    muted_attr = curses.A_DIM
    warn_attr = pair(4) | curses.A_BOLD
    add_line(stdscr, 0, 0, "Shairport Sync", title_attr)
    add_line(stdscr, 0, max(0, width - 22), dt.datetime.now().strftime("%Y-%m-%d %H:%M:%S"), muted_attr)
    add_line(stdscr, 1, 0, "-" * max(0, width - 1), muted_attr)
    if message:
        add_line(stdscr, 2, 0, message, warn_attr if message.startswith("error") else muted_attr)


def draw_footer(stdscr: curses.window, view: str) -> None:
    height, width = stdscr.getmaxyx()
    muted_attr = curses.A_DIM
    if height <= 2:
        return

    if view == "debug":
        if width < 72:
            text = "0-5 Filter  j/k Scroll  d Main  ? Help  q"
        else:
            text = "0 All  1 Detail  2 Svc  3 Audio  4 Hist  5 Logs  j/k Scroll  d Main  q Quit"
    elif view == "help":
        text = "?/h Back  q Quit"
    else:
        if width < 72:
            text = "Space Play  n/p  +/-  d Debug  ? Help  q"
        else:
            text = "Space Play/Pause  n Next  p Prev  +/- Vol  d Debug  ? Help  q Quit"
    add_line(stdscr, height - 1, 0, text, muted_attr)


def draw_main(
    stdscr: curses.window,
    snap: Snapshot,
    refresh_seconds: float,
    message: str,
) -> None:
    stdscr.erase()
    height, width = stdscr.getmaxyx()
    title_attr = pair(1) | curses.A_BOLD
    muted_attr = curses.A_DIM
    good_attr = pair(3) | curses.A_BOLD
    warn_attr = pair(4) | curses.A_BOLD

    draw_header(stdscr, message)

    if not snap.ok:
        add_line(stdscr, 4, 0, "Status", warn_attr)
        add_line(stdscr, 5, 2, snap.error or "Unable to read Shairport Sync.", warn_attr)
        add_line(stdscr, 7, 2, "Check shairport-sync and system D-Bus access.", muted_attr)
        draw_footer(stdscr, "main")
        stdscr.refresh()
        return

    connected = snap.available and snap.client
    status = "Connected" if connected else "Idle"
    status_attr = good_attr if connected else muted_attr

    volume = "-"
    if snap.airplay_volume is not None:
        volume = f"{snap.airplay_volume:.1f} dB"
        if snap.volume_percent is not None and width >= 72:
            volume += f" ({snap.volume_percent:.0f}%)"

    client_label = "Client" if connected else "Last client"
    client_value = snap.client or "-"
    if snap.client_name and width >= 72:
        client_value = f"{client_value} ({snap.client_name})"

    row = 3
    add_line(stdscr, row, 0, status, status_attr)
    add_line(stdscr, row, 14, f"{client_label}: {client_value}", muted_attr, max_width=max(12, width - 42))
    add_line(stdscr, row, max(0, width - 24), f"Vol: {volume}", muted_attr)

    row += 2
    add_line(stdscr, row, 0, "Now Playing", title_attr)
    row += 2
    add_line(stdscr, row, 2, snap.title or "-", curses.A_BOLD)
    row += 1
    add_line(stdscr, row, 2, snap.artist or "-", title_attr)

    album_line = snap.album or "-"
    if snap.genre and width >= 72:
        album_line = f"{album_line} | {snap.genre}"
    row += 1
    add_line(stdscr, row, 2, album_line, muted_attr)
    if snap.art_url and height >= 26:
        row += 1
        add_line(stdscr, row, 2, f"Artwork: {snap.art_url}", muted_attr)

    estimated = " estimated" if snap.progress_estimated else ""
    row += 2
    add_line(stdscr, row, 2, f"{format_seconds(snap.elapsed_seconds)} / {format_seconds(snap.duration_seconds)}{estimated}", muted_attr)
    fraction = None
    if snap.elapsed_seconds is not None and snap.duration_seconds:
        fraction = snap.elapsed_seconds / snap.duration_seconds
    row += 1
    draw_bar(stdscr, row, 2, max(8, width - 5), fraction)

    if height >= 20:
        row += 3
        add_line(stdscr, row, 0, "Playback", title_attr)
        row += 1
        add_line(stdscr, row, 2, f"State: {snap.player_state or '-'}")
        row += 1
        add_line(stdscr, row, 2, f"AirPlay session: {'yes' if snap.active else 'no'}")

    draw_footer(stdscr, "main")
    stdscr.refresh()


def draw_debug(
    stdscr: curses.window,
    snap: Snapshot,
    system: SystemSnapshot,
    history: HistoryStore,
    refresh_seconds: float,
    message: str,
    scroll: int,
    section_filter: str,
) -> int:
    stdscr.erase()
    height, width = stdscr.getmaxyx()
    title_attr = pair(1) | curses.A_BOLD
    muted_attr = curses.A_DIM
    good_attr = pair(3) | curses.A_BOLD
    warn_attr = pair(4) | curses.A_BOLD

    draw_header(stdscr, message)
    add_line(stdscr, 3, 0, "Debug", title_attr)
    add_line(stdscr, 3, max(0, width - 18), f"Filter: {section_filter}", muted_attr)

    rows: list[tuple[int, Any, int]] = []
    if section_filter in ("all", "now-playing"):
        rows.append((0, "Now Playing Details", title_attr))
        rows.append((2, f"Title: {snap.title or '-'}", 0))
        rows.append((2, f"Artist: {snap.artist or '-'}", 0))
        rows.append((2, f"Album: {snap.album or '-'}", 0))
        rows.append((2, f"Genre: {snap.genre or '-'}", 0))
        rows.append((2, f"Artwork: {snap.art_url or '-'}", muted_attr))
        rows.append((0, "", 0))

    if section_filter in ("all", "services"):
        rows.append((0, "Service Health", title_attr))
        for unit in system.units:
            state = f"{unit.active}/{unit.sub}"
            attr = good_attr if unit.active == "active" else warn_attr
            rows.append((2, f"{unit.name}: {state} pid={unit.pid} restarts={unit.restarts}", attr))
            if unit.error:
                rows.append((4, unit.error, warn_attr))
        rows.append((0, "", 0))

    if section_filter in ("all", "audio"):
        audio = system.audio
        rows.append((0, "Audio Output", title_attr))
        rows.append((2, f"Backend: {audio.backend}   Output: {audio.output_device}   Mixer: {audio.mixer} {audio.alsa_volume}", 0))
        rows.append((2, f"Pulse: {audio.default_sink or audio.pulse_server or '-'}", 0))
        for device in audio.devices[:3]:
            rows.append((2, device, muted_attr))
        for error in audio.errors[:2]:
            rows.append((2, error, warn_attr))
        rows.append((0, "", 0))

    if section_filter in ("all", "history"):
        rows.append((0, "Connection History", title_attr))
        if history.items:
            for item in history.items:
                track = item.get("last_track", "-")
                name = item.get("client_name", "")
                client = item.get("client", "-")
                if name:
                    client = f"{client} ({name})"
                rows.append((2, f"{client} | {item.get('last_state', '-')} | {track}", 0))
        else:
            rows.append((2, "No history yet.", muted_attr))
        rows.append((0, "", 0))

    if section_filter in ("all", "logs"):
        rows.append((0, "Recent Logs", title_attr))
        for line in system.logs:
            rows.append((2, line, muted_attr))

    if not rows:
        rows.append((0, "No debug rows for this filter.", muted_attr))

    start_row = 5
    available = max(1, height - start_row - 1)
    max_scroll = max(0, len(rows) - available)
    scroll = max(0, min(scroll, max_scroll))
    for screen_row, (indent, text, attr) in enumerate(rows[scroll : scroll + available], start=start_row):
        add_line(stdscr, screen_row, indent, text, attr)

    if height > 4:
        position = f"scroll {scroll}/{max_scroll}" if max_scroll else "scroll 0/0"
        add_line(stdscr, height - 2, 0, f"{position} | Build: {snap.version or '-'}", muted_attr)
    draw_footer(stdscr, "debug")
    stdscr.refresh()
    return max_scroll


def draw_help(stdscr: curses.window, refresh_seconds: float, message: str) -> None:
    stdscr.erase()
    title_attr = pair(1) | curses.A_BOLD
    muted_attr = curses.A_DIM
    draw_header(stdscr, message)
    add_line(stdscr, 3, 0, "Help", title_attr)
    lines = [
        ("Keys", title_attr),
        ("  Space       Play or pause", 0),
        ("  n / p       Next / previous track", 0),
        ("  + / -       Volume up / down", 0),
        ("  m           Toggle mute", 0),
        ("  s           Stop playback", 0),
        ("  d           Toggle main/debug view", 0),
        ("  0-5         Debug filters: all/details/services/audio/history/logs", 0),
        ("  r           Refresh now", 0),
        ("  j/k, arrows Scroll debug view", 0),
        ("  C           Clear connection history, with confirmation", 0),
        ("  ? or h      Toggle this help", 0),
        ("  q or Esc    Quit", 0),
        ("", 0),
        ("Commands", title_attr),
        ("  shairport-tui --doctor         Check services, D-Bus, logs, and audio", 0),
        ("  shairport-tui --clear-history  Delete saved connection history", 0),
        ("  shairport-tui --write-config   Write a default config file", 0),
        ("  shairport-tui --no-color       Disable color output", 0),
        ("", 0),
        ("Press ? or h to return.", muted_attr),
    ]
    height, _width = stdscr.getmaxyx()
    for row, (text, attr) in enumerate(lines, start=5):
        if row >= height - 1:
            break
        add_line(stdscr, row, 0, text, attr)
    draw_footer(stdscr, "help")
    stdscr.refresh()


def read_snapshot(reader: ShairportReader | None) -> tuple[ShairportReader | None, Snapshot]:
    try:
        if reader is None:
            reader = ShairportReader()
        return reader, reader.read()
    except Exception as exc:
        return None, Snapshot(ok=False, error=str(exc))


def handle_key(key: int, reader: ShairportReader | None) -> tuple[str | None, bool]:
    if key in (ord("q"), ord("Q"), 27):
        return None, True
    if key < 0:
        return None, False
    if reader is None:
        return "error: Shairport D-Bus unavailable", False
    mapping = {
        ord(" "): "toggle",
        ord("n"): "next",
        ord("N"): "next",
        ord("p"): "previous",
        ord("P"): "previous",
        ord("s"): "stop",
        ord("S"): "stop",
        ord("m"): "mute",
        ord("M"): "mute",
        ord("+"): "volume_up",
        ord("="): "volume_up",
        ord("-"): "volume_down",
        ord("_"): "volume_down",
    }
    action = mapping.get(key)
    if not action:
        return None, False
    try:
        method = reader.command(action)
    except Exception as exc:
        return f"error: {exc}", False
    labels = {
        "PlayPause": "play/pause",
        "Next": "next track",
        "Previous": "previous track",
        "Stop": "stop",
        "ToggleMute": "mute toggle",
        "VolumeUp": "volume up",
        "VolumeDown": "volume down",
    }
    return f"sent {labels.get(method, method)}", False


def run(stdscr: curses.window, refresh_seconds: float, default_view: str) -> None:
    global USE_COLOR
    USE_COLOR = USE_COLOR and curses.has_colors()
    if USE_COLOR and curses.has_colors():
        curses.use_default_colors()
        curses.init_pair(1, curses.COLOR_CYAN, -1)
        curses.init_pair(3, curses.COLOR_GREEN, -1)
        curses.init_pair(4, curses.COLOR_RED, -1)
    curses.curs_set(0)
    stdscr.keypad(True)
    stdscr.nodelay(True)
    stdscr.timeout(max(50, min(250, int(refresh_seconds * 1000 / 4))))

    reader: ShairportReader | None = None
    progress_clock = ProgressClock()
    system_reader = SystemReader()
    history = HistoryStore()
    snap = Snapshot(ok=False, error="Starting...")
    system = system_reader.read(force=True)
    next_refresh = 0.0
    message = ""
    message_until = 0.0
    view = default_view if default_view in ("main", "debug") else "main"
    previous_view = view
    debug_scroll = 0
    debug_max_scroll = 0
    debug_filter = "all"
    clear_confirm_until = 0.0
    history_pause_until = 0.0

    while True:
        now = time.monotonic()
        if now >= next_refresh:
            reader, snap = read_snapshot(reader)
            if snap.ok:
                snap = progress_clock.apply(snap)
                if now >= history_pause_until:
                    history.record(snap)
            system = system_reader.read()
            if now >= message_until:
                message = ""
            if view == "help":
                draw_help(stdscr, refresh_seconds, message)
            elif view == "debug":
                debug_max_scroll = draw_debug(stdscr, snap, system, history, refresh_seconds, message, debug_scroll, debug_filter)
                debug_scroll = min(debug_scroll, debug_max_scroll)
            else:
                draw_main(stdscr, snap, refresh_seconds, message)
            next_refresh = now + refresh_seconds

        key = stdscr.getch()
        if key in (ord("r"), ord("R")):
            next_refresh = 0.0
            system = system_reader.read(force=True)
            continue
        if key in (ord("?"), ord("h"), ord("H")):
            if view == "help":
                view = previous_view
            else:
                previous_view = view
                view = "help"
            next_refresh = 0.0
            continue
        if key in (ord("d"), ord("D")):
            if view == "help":
                previous_view = "debug" if previous_view == "main" else "main"
            else:
                view = "debug" if view == "main" else "main"
            next_refresh = 0.0
            continue
        if key == ord("C"):
            if time.monotonic() <= clear_confirm_until:
                history.clear()
                message = "connection history cleared"
                message_until = time.monotonic() + 2.5
                clear_confirm_until = 0.0
                history_pause_until = time.monotonic() + 5.0
            else:
                message = "press C again to clear connection history"
                message_until = time.monotonic() + 4.0
                clear_confirm_until = time.monotonic() + 4.0
            next_refresh = 0.0
            continue
        if view == "debug":
            filters = {
                ord("0"): "all",
                ord("1"): "now-playing",
                ord("2"): "services",
                ord("3"): "audio",
                ord("4"): "history",
                ord("5"): "logs",
            }
            if key in filters:
                debug_filter = filters[key]
                debug_scroll = 0
                next_refresh = 0.0
                continue
            page = max(1, stdscr.getmaxyx()[0] - 7)
            if key in (ord("j"), curses.KEY_DOWN):
                debug_scroll = min(debug_scroll + 1, debug_max_scroll)
                next_refresh = 0.0
                continue
            if key in (ord("k"), curses.KEY_UP):
                debug_scroll = max(0, debug_scroll - 1)
                next_refresh = 0.0
                continue
            if key in (curses.KEY_NPAGE, ord("f")):
                debug_scroll = min(debug_scroll + page, debug_max_scroll)
                next_refresh = 0.0
                continue
            if key in (curses.KEY_PPAGE, ord("b")):
                debug_scroll = max(0, debug_scroll - page)
                next_refresh = 0.0
                continue
            if key in (curses.KEY_HOME, ord("g")):
                debug_scroll = 0
                next_refresh = 0.0
                continue
            if key in (curses.KEY_END, ord("G")):
                debug_scroll = debug_max_scroll
                next_refresh = 0.0
                continue
        new_message, should_quit = handle_key(key, reader)
        if should_quit:
            return
        if new_message:
            message = new_message
            message_until = time.monotonic() + 2.5
            next_refresh = 0.0


def check_line(label: str, ok: bool, detail: str) -> str:
    status = "ok" if ok else "fail"
    return f"{status:4} {label}: {detail}"


def doctor() -> int:
    failures = 0
    print("shairport-tui doctor")
    print()

    for command in ("python3", "systemctl", "journalctl", "pactl", "amixer", "aplay"):
        path = shutil.which(command)
        ok = path is not None
        failures += 0 if ok else 1
        print(check_line(command, ok, path or "not found"))

    print(check_line("python3-dbus", dbus is not None, "importable" if dbus is not None else "not importable"))
    if dbus is None:
        failures += 1
    else:
        try:
            snap = ShairportReader().read()
            print(check_line("Shairport D-Bus", snap.ok, snap.version or snap.error))
            print(check_line("Current client", bool(snap.client), snap.client or "none"))
        except Exception as exc:
            failures += 1
            print(check_line("Shairport D-Bus", False, str(exc)))

    for unit_name in ("shairport-sync.service", "avahi-daemon.service"):
        unit = read_unit(unit_name)
        ok = unit.active == "active"
        failures += 0 if ok else 1
        detail = f"{unit.active}/{unit.sub} pid={unit.pid}"
        if unit.error:
            detail = unit.error
        print(check_line(unit_name, ok, detail))

    config = parse_config()
    print(check_line("config", bool(config), str(CONFIG_PATH) if config else "no explicit output settings found"))
    if config:
        print(f"     backend={config.get('output_backend', 'alsa')} output={config.get('output_device', '-')} mixer={config.get('mixer_control_name', '-')}")

    ok, output = run_cmd(["journalctl", "-u", "shairport-sync.service", "-n", "1", "--no-pager"], timeout=4.0)
    print(check_line("journal", ok, output.splitlines()[-1] if output else "readable"))

    audio = read_audio()
    print(check_line("audio config", True, f"backend={audio.backend} output={audio.output_device} mixer={audio.mixer} volume={audio.alsa_volume}"))
    if audio.errors:
        print("     audio warnings:")
        for error in audio.errors[:3]:
            print(f"     - {error}")

    print()
    print(f"History file: {HISTORY_PATH}")
    return 1 if failures else 0


def main() -> None:
    global HISTORY_LIMIT, LOG_LINES, USE_COLOR
    parser = argparse.ArgumentParser(description="Terminal dashboard for Shairport Sync.")
    parser.add_argument("--version", action="version", version=f"shairport-tui {VERSION}")
    parser.add_argument(
        "-i",
        "--interval",
        type=float,
        default=None,
        help=f"auto-refresh interval in seconds (default: config or {DEFAULT_REFRESH_SECONDS:g})",
    )
    parser.add_argument("--doctor", action="store_true", help="run diagnostics and exit")
    parser.add_argument("--clear-history", action="store_true", help="delete saved connection history and exit")
    parser.add_argument("--config", default=str(APP_CONFIG_PATH), help="path to config JSON")
    parser.add_argument("--write-config", action="store_true", help="write a default config file and exit")
    parser.add_argument("--no-color", action="store_true", help="disable color output")
    args = parser.parse_args()

    config_path = Path(args.config).expanduser()
    if args.write_config:
        write_default_config(config_path)
        print(f"Wrote config: {config_path}")
        raise SystemExit(0)

    config = load_app_config() if config_path == APP_CONFIG_PATH else load_app_config_from(config_path)
    refresh_seconds = args.interval if args.interval is not None else float(config["refresh_interval"])
    if refresh_seconds <= 0:
        parser.error("--interval must be greater than 0")

    HISTORY_LIMIT = int(config["history_limit"])
    LOG_LINES = int(config["log_lines"])
    USE_COLOR = bool(config["color"]) and not args.no_color

    if args.doctor:
        raise SystemExit(doctor())
    if args.clear_history:
        history = HistoryStore()
        history.clear()
        print(f"Cleared history: {HISTORY_PATH}")
        raise SystemExit(0)

    if not sys.stdin.isatty() or not sys.stdout.isatty():
        print("shairport-tui needs an interactive terminal.", file=sys.stderr)
        raise SystemExit(2)
    signal.signal(signal.SIGINT, lambda _signum, _frame: raise_keyboard_interrupt())
    curses.wrapper(run, refresh_seconds, str(config["default_view"]))


def raise_keyboard_interrupt() -> None:
    raise KeyboardInterrupt


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        pass
